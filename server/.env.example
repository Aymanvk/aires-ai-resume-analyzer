# ─── Server ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ─────────────────────────────────────────────
# Replace <username>, <password>, and <dbname> with your Atlas credentials
# For local dev use: mongodb://127.0.0.1:27017/aires
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── JWT ─────────────────────────────────────────────────
# Use a long, random, unguessable secret (min 32 chars recommended)
# Generate one with:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_very_long_random_secret
JWT_EXPIRES_IN=7d

# ─── CORS ────────────────────────────────────────────────
# The URL of your React frontend (no trailing slash)
FRONTEND_ORIGIN=http://localhost:5173
